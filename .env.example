# Asaas - Plataforma de pagamento
# Obtenha em: asaas.com → Configurações → Integrações → Chaves de API
ASAAS_API_KEY=

# Ambiente: sandbox (testes) ou production (produção)
ASAAS_ENV=sandbox

# Token do Webhook do Asaas
# Obtenha em: asaas.com → Configurações → Integrações → Webhooks
ASAAS_WEBHOOK_TOKEN=

# Supabase
# Obtenha em: supabase.com → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

PORT=3001
DATABASE_PATH=./data/app.sqlite

# Frontend (Vite)
VITE_API_URL=https://seu-backend.railway.app
VITE_CAKTO_CHECKOUT_MENSAL_URL=
VITE_CAKTO_CHECKOUT_VITALICIO_URL=
